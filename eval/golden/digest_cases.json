{
  "suite": "digest",
  "schema_version": 1,
  "cases": [
    {
      "case_id": "digest_sample_structured_result",
      "scenario": "digest",
      "fixture": "sample_vault",
      "description": "基于真实 sample_vault 的最小 DAILY_DIGEST 回归，确认当前至少能稳定产出结构化摘要。",
      "request": {
        "action_type": "daily_digest",
        "require_approval": false
      },
      "setup": {
        "provider_mode": "none"
      },
      "expected": {
        "http_status": 200,
        "workflow_status": "completed",
        "message_contains": "indexed note digest",
        "approval_required": false,
        "digest_result": {
          "fallback_used": false,
          "min_source_note_count": 1,
          "markdown_contains": [
            "本次 DAILY_DIGEST 基于最近",
            "重点来源"
          ]
        }
      }
    },
    {
      "case_id": "digest_fixture_structured_result_metrics",
      "scenario": "digest",
      "fixture": "digest_basic",
      "description": "deterministic digest fixture 应稳定产出结构化摘要，并给出可解释的上下文覆盖指标。",
      "quality_reference": {
        "reference_context_path_suffixes": [
          "2026-03-14.md",
          "2026-03-13.md",
          "迭代总结.md"
        ]
      },
      "request": {
        "action_type": "daily_digest",
        "require_approval": false
      },
      "setup": {
        "provider_mode": "none"
      },
      "expected": {
        "http_status": 200,
        "workflow_status": "completed",
        "message_contains": "indexed note digest",
        "approval_required": false,
        "digest_result": {
          "fallback_used": false,
          "source_note_count": 3,
          "markdown_contains": [
            "本次 DAILY_DIGEST 基于最近 3 篇已索引笔记生成。",
            "重点来源"
          ],
          "source_note_path_suffixes": [
            "2026-03-14.md",
            "2026-03-13.md",
            "迭代总结.md"
          ]
        },
        "quality_metrics": {
          "faithfulness": {
            "min": 1.0
          },
          "coverage": {
            "min": 1.0
          }
        }
      }
    },
    {
      "case_id": "digest_sample_waiting_proposal",
      "scenario": "digest",
      "fixture": "sample_vault",
      "description": "真实 sample_vault 下启用 proposal 模式时，应返回 waiting_for_approval 和结构化 proposal。",
      "request": {
        "action_type": "daily_digest",
        "require_approval": true,
        "metadata": {
          "approval_mode": "proposal"
        }
      },
      "setup": {
        "provider_mode": "none"
      },
      "expected": {
        "http_status": 202,
        "workflow_status": "waiting_for_approval",
        "message_contains": "waiting for approval",
        "approval_required": true,
        "digest_result": {
          "fallback_used": false,
          "min_source_note_count": 1,
          "markdown_contains": "本次 DAILY_DIGEST 基于最近"
        },
        "proposal": {
          "present": true,
          "patch_ops": [
            "merge_frontmatter",
            "insert_under_heading"
          ],
          "target_note_path_suffix": ".md",
          "summary_contains": "DAILY_DIGEST"
        }
      }
    },
    {
      "case_id": "digest_fixture_waiting_proposal_metrics",
      "scenario": "digest",
      "fixture": "digest_basic",
      "description": "deterministic digest fixture 在 proposal 模式下应返回 waiting proposal，并把 source note 作为最小上下文证据。",
      "quality_reference": {
        "reference_context_path_suffixes": [
          "2026-03-14.md",
          "2026-03-13.md",
          "迭代总结.md"
        ]
      },
      "request": {
        "thread_id": "thread_eval_digest_waiting",
        "action_type": "daily_digest",
        "require_approval": true,
        "metadata": {
          "approval_mode": "proposal"
        }
      },
      "setup": {
        "provider_mode": "none"
      },
      "expected": {
        "http_status": 202,
        "workflow_status": "waiting_for_approval",
        "message_contains": "waiting for approval",
        "approval_required": true,
        "digest_result": {
          "fallback_used": false,
          "source_note_count": 3,
          "markdown_contains": "本次 DAILY_DIGEST 基于最近 3 篇已索引笔记生成。",
          "source_note_path_suffixes": [
            "2026-03-14.md",
            "2026-03-13.md",
            "迭代总结.md"
          ]
        },
        "proposal": {
          "present": true,
          "patch_ops": [
            "merge_frontmatter",
            "insert_under_heading"
          ],
          "target_note_path_suffix": "2026-03-14.md",
          "summary_contains": "DAILY_DIGEST",
          "min_evidence_count": 3,
          "evidence_path_suffixes": [
            "2026-03-14.md",
            "2026-03-13.md",
            "迭代总结.md"
          ]
        },
        "quality_metrics": {
          "faithfulness": {
            "min": 1.0
          },
          "coverage": {
            "min": 1.0
          }
        }
      }
    },
    {
      "case_id": "digest_fixture_empty_index_fallback",
      "scenario": "digest",
      "fixture": "empty_index",
      "description": "空索引下 digest 应返回安全 fallback，而不是抛异常或空 proposal。",
      "request": {
        "action_type": "daily_digest",
        "require_approval": false
      },
      "setup": {
        "provider_mode": "none"
      },
      "expected": {
        "http_status": 200,
        "workflow_status": "completed",
        "message_contains": "safe fallback",
        "approval_required": false,
        "digest_result": {
          "fallback_used": true,
          "fallback_reason": "no_indexed_notes",
          "source_note_count": 0,
          "markdown_contains": "请先执行一次 INGEST_STEWARD"
        }
      }
    }
  ]
}
