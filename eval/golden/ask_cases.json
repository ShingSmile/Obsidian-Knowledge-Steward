          "Strategy.md"
        ]
      },
      "request": {
        "action_type": "ask_qa",
        "user_query": "Roadmap"
      },
      "setup": {
        "provider_mode": "none",
        "mock_embedding_profile": "roadmap_strategy_hybrid",
        "prewarm_requests": [
