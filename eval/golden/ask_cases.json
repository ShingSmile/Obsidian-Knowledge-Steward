    {
      "case_id": "ask_fixture_hybrid_retrieval_only",
      "scenario": "ask",
      "fixture": "ask_hybrid_basic",
      "description": "在 deterministic hybrid fixture 下，ask 应显式消费 hybrid candidate，而不是只回归纯 FTS。",
      "quality_reference": {
        "reference_context_path_suffixes": [
