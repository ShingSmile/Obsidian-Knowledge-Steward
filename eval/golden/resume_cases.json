{
  "suite": "resume",
  "schema_version": 1,
  "cases": [
    {
      "case_id": "resume_fixture_reject_waiting_proposal",
      "scenario": "resume_workflow",
      "entrypoint": "resume",
      "fixture": "resume_waiting_digest",
      "description": "对 waiting proposal 执行 reject，应完成 checkpoint 并写入 rejection audit，而不会生成 writeback_result。",
      "request": {
        "thread_id": "thread_resume_digest",
        "proposal_id": "prop_digest_resume",
        "approval_decision": {
          "approved": false,
          "reviewer": "eval_reject_reviewer",
          "comment": "risk too high"
        }
      },
      "setup": {
        "provider_mode": "none"
      },
      "expected": {
        "http_status": 200,
        "workflow_status": "completed",
        "message_contains": "recorded rejection",
        "approval_required": false,
        "approval_decision": {
          "approved": false,
          "reviewer": "eval_reject_reviewer",
          "approved_patch_op_count": 0
        },
        "writeback_result": {
          "present": false
        },
        "checkpoint": {
          "present": true,
          "status": "completed",
          "approval_required": false,
          "patch_plan_count": 0,
          "approval_decision_approved": false,
          "writeback_result_present": false
        },
        "audit_log": {
          "present": true,
          "approval_status": "rejected",
          "reviewer": "eval_reject_reviewer",
          "writeback_applied": false,
          "error": null
        }
      }
    },
    {
      "case_id": "resume_fixture_writeback_success",
      "scenario": "resume_workflow",
      "entrypoint": "resume",
      "fixture": "resume_waiting_digest",
      "description": "approve 后附带成功 writeback_result，应写入 completed checkpoint 和成功审计记录。",
      "request": {
        "thread_id": "thread_resume_digest",
        "proposal_id": "prop_digest_resume",
        "approval_decision": {
          "approved": true,
          "reviewer": "eval_success_reviewer",
          "comment": "apply now"
        },
        "writeback_result": {
          "applied": true,
          "target_note_path": "Digest/2026-03-14.md",
          "before_hash": "sha256:resume_before",
          "after_hash": "sha256:after_success",
          "applied_patch_ops": [
            {
              "op": "frontmatter_merge",
              "target_path": "Digest/2026-03-14.md",
              "payload": {
                "reviewed": false
              }
            },
            {
              "op": "insert_under_heading",
              "target_path": "Digest/2026-03-14.md",
              "payload": {
                "heading_path": "## Digest",
                "content": "- Review retrieval fallback cases"
              }
            }
          ]
        }
      },
      "setup": {
        "provider_mode": "none"
      },
      "expected": {
        "http_status": 200,
        "workflow_status": "completed",
        "message_contains": "successful writeback result",
        "approval_required": false,
        "approval_decision": {
          "approved": true,
          "reviewer": "eval_success_reviewer",
          "approved_patch_op_count": 2
        },
        "writeback_result": {
          "present": true,
          "applied": true,
          "before_hash": "sha256:resume_before",
          "after_hash": "sha256:after_success",
          "applied_patch_op_count": 2,
          "error": null
        },
        "checkpoint": {
          "present": true,
          "status": "completed",
          "approval_required": false,
          "patch_plan_count": 2,
          "approval_decision_approved": true,
          "writeback_result_present": true,
          "writeback_applied": true,
          "writeback_after_hash": "sha256:after_success"
        },
        "audit_log": {
          "present": true,
          "approval_status": "approved",
          "reviewer": "eval_success_reviewer",
          "writeback_applied": true,
          "before_hash": "sha256:resume_before",
          "after_hash": "sha256:after_success",
          "error": null
        }
      }
    },
    {
      "case_id": "resume_fixture_writeback_failure",
      "scenario": "resume_workflow",
      "entrypoint": "resume",
      "fixture": "resume_waiting_digest",
      "description": "approve 后附带失败 writeback_result，应保留 completed checkpoint 和失败审计事实，不能伪装成成功写回。",
      "request": {
        "thread_id": "thread_resume_digest",
        "proposal_id": "prop_digest_resume",
        "approval_decision": {
          "approved": true,
          "reviewer": "eval_failed_reviewer",
          "comment": "record the failure"
        },
        "writeback_result": {
          "applied": false,
          "target_note_path": "Digest/2026-03-14.md",
          "before_hash": "sha256:current_hash",
          "applied_patch_ops": [],
          "error": "before_hash mismatch: current file changed"
        }
      },
      "setup": {
        "provider_mode": "none"
      },
      "expected": {
        "http_status": 200,
        "workflow_status": "completed",
        "message_contains": "failed writeback result",
        "approval_required": false,
        "approval_decision": {
          "approved": true,
          "reviewer": "eval_failed_reviewer",
          "approved_patch_op_count": 2
        },
        "writeback_result": {
          "present": true,
          "applied": false,
          "before_hash": "sha256:current_hash",
          "applied_patch_op_count": 0,
          "error_contains": "before_hash mismatch"
        },
        "checkpoint": {
          "present": true,
          "status": "completed",
          "approval_required": false,
          "patch_plan_count": 2,
          "approval_decision_approved": true,
          "writeback_result_present": true,
          "writeback_applied": false,
          "writeback_error_contains": "before_hash mismatch"
        },
        "audit_log": {
          "present": true,
          "approval_status": "approved",
          "reviewer": "eval_failed_reviewer",
          "writeback_applied": false,
          "before_hash": "sha256:current_hash",
          "after_hash": null,
          "error_contains": "before_hash mismatch"
        }
      }
    }
  ]
}
